{
  "name": "big-cup-club",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.2",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:demo": "pnpm --filter @bigcup/demo dev",
    "db:up": "docker compose up -d postgres redis",
    "db:migrate": "pnpm --filter @bigcup/api exec -- prisma migrate dev",
    "db:seed": "pnpm --filter @bigcup/api exec -- tsx prisma/seed.ts",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@bigcup/demo --filter=@bigcup/admin-web --filter=@bigcup/partner-web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
